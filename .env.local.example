# ─── Supabase Auth ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key

# ─── Drizzle / Postgres ─────────────────────────────────────────
# Runtime queries — transaction pooler, port 6543
DATABASE_URL="postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-region.pooler.supabase.com:6543/postgres"

# Migrations only — direct connection, port 5432
DIRECT_URL="postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-region.pooler.supabase.com:5432/postgres"

# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# test push again